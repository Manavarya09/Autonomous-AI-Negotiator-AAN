FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir --upgrade pip

RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    sqlalchemy[asyncio] \
    asyncpg \
    pydantic \
    pydantic-settings \
    pydantic[email] \
    email-validator \
    python-dotenv \
    httpx \
    aiohttp \
    celery \
    redis \
    prometheus-client \
    structlog \
    pyjwt \
    passlib[bcrypt] \
    litellm \
    beautifulsoup4 \
    lxml \
    playwright \
    stripe \
    python-telegram-bot

COPY config/ ./config/
COPY services/ ./services/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["uvicorn", "services.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]